<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ===== Shared Resources ===== -->
  <Styles.Resources>
    <!-- Accent colors that work in both light/dark -->
    <Color x:Key="TwAccent">#0078D4</Color>
    <Color x:Key="TwAccentLight">#429CE3</Color>
    <Color x:Key="TwAccentDark">#005A9E</Color>

    <!-- Spacing constants (referenced as StaticResource) -->
    <x:Double x:Key="PagePadding">16</x:Double>
    <x:Double x:Key="SectionSpacing">12</x:Double>
    <x:Double x:Key="ItemSpacing">8</x:Double>
    <Thickness x:Key="PageMargin">16</Thickness>
    <Thickness x:Key="SectionMargin">0,0,0,12</Thickness>
    <Thickness x:Key="CardPadding">16</Thickness>
    <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="InputCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="ButtonCornerRadius">6</CornerRadius>

    <!-- Card brushes (theme-aware) -->
    <SolidColorBrush x:Key="CardBackgroundLight" Color="#FFFFFF" />
    <SolidColorBrush x:Key="CardBorderLight" Color="#E0E0E0" />
    <SolidColorBrush x:Key="CardBackgroundDark" Color="#2D2D2D" />
    <SolidColorBrush x:Key="CardBorderDark" Color="#404040" />

    <!-- Banner brushes -->
    <LinearGradientBrush x:Key="BannerGradientLight" StartPoint="0%,0%" EndPoint="100%,0%">
      <GradientStop Color="#0078D4" Offset="0" />
      <GradientStop Color="#429CE3" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BannerGradientDark" StartPoint="0%,0%" EndPoint="100%,0%">
      <GradientStop Color="#1A3A5C" Offset="0" />
      <GradientStop Color="#2D5F8A" Offset="1" />
    </LinearGradientBrush>
  </Styles.Resources>

  <!-- ===== Card Panel Style ===== -->
  <Style Selector="Border.card">
    <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}" />
    <Setter Property="Padding" Value="{StaticResource CardPadding}" />
    <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <!-- Light theme card override -->
  <Style Selector="Border.card">
    <Style.Resources>
      <ResourceDictionary>
        <ResourceDictionary.ThemeDictionaries>
          <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="CardBg" Color="#FFFFFF" />
            <SolidColorBrush x:Key="CardBd" Color="#E5E5E5" />
          </ResourceDictionary>
          <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="CardBg" Color="#2D2D2D" />
            <SolidColorBrush x:Key="CardBd" Color="#404040" />
          </ResourceDictionary>
        </ResourceDictionary.ThemeDictionaries>
      </ResourceDictionary>
    </Style.Resources>
    <Setter Property="Background" Value="{DynamicResource CardBg}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardBd}" />
  </Style>

  <!-- ===== Section Header Style ===== -->
  <Style Selector="TextBlock.sectionHeader">
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Margin" Value="0,0,0,8" />
  </Style>

  <Style Selector="TextBlock.pageTitle">
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="FontSize" Value="20" />
    <Setter Property="Margin" Value="0,0,0,4" />
  </Style>

  <Style Selector="TextBlock.subtitle">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
  </Style>

  <!-- ===== Modern Button Row ===== -->
  <Style Selector="StackPanel.buttonRow">
    <Setter Property="Orientation" Value="Horizontal" />
    <Setter Property="HorizontalAlignment" Value="Right" />
    <Setter Property="Spacing" Value="8" />
    <Setter Property="Margin" Value="0,8,0,0" />
  </Style>

  <!-- ===== Rounded TextBox ===== -->
  <Style Selector="TextBox">
    <Setter Property="CornerRadius" Value="{StaticResource InputCornerRadius}" />
  </Style>

  <!-- ===== Rounded ComboBox ===== -->
  <Style Selector="ComboBox">
    <Setter Property="CornerRadius" Value="{StaticResource InputCornerRadius}" />
  </Style>

  <!-- ===== Button Styling ===== -->
  <Style Selector="Button">
    <Setter Property="CornerRadius" Value="{StaticResource ButtonCornerRadius}" />
    <Setter Property="Padding" Value="16,6" />
  </Style>

  <!-- Primary action button -->
  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource SystemAccentColor}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <!-- ===== DataGrid Improvements ===== -->
  <Style Selector="DataGrid">
    <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}" />
    <Setter Property="GridLinesVisibility" Value="None" />
  </Style>

  <Style Selector="DataGridColumnHeader">
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Padding" Value="12,8" />
  </Style>

  <Style Selector="DataGridCell">
    <Setter Property="Padding" Value="12,6" />
  </Style>

  <!-- Subtle alternating row colors — very low opacity for gentle striping -->
  <Style Selector="DataGridRow:nth-child(even)">
    <Setter Property="Background">
      <Setter.Value>
        <SolidColorBrush Color="#808080" Opacity="0.04" />
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ===== CheckBox / RadioButton Spacing ===== -->
  <Style Selector="CheckBox">
    <Setter Property="Margin" Value="0,2" />
  </Style>

  <Style Selector="RadioButton">
    <Setter Property="Margin" Value="0,3" />
  </Style>

  <!-- ===== ListBox within cards ===== -->
  <Style Selector="ListBox">
    <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}" />
  </Style>

  <!-- ===== Banner style ===== -->
  <Style Selector="Border.banner">
    <Setter Property="CornerRadius" Value="0,0,12,12" />
    <Setter Property="Padding" Value="20,16" />
    <Setter Property="MinHeight" Value="56" />
  </Style>

  <Style Selector="Border.banner TextBlock">
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="14" />
  </Style>

  <!-- ===== Tab Control ===== -->
  <Style Selector="TabItem">
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Padding" Value="16,8" />
  </Style>

</Styles>
