<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:pylorak.TinyWall.ViewModels"
             x:Class="pylorak.TinyWall.Views.ApplicationsPage">

  <Grid Margin="16" RowDefinitions="Auto,12,Auto,12,*,8,Auto,8,Auto">

    <!-- Header -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
      <TextBlock Text="Applications" Classes="pageTitle" />
      <TextBlock Classes="pageTitleInfo" ToolTip.Tip="Manage application exceptions that control which programs are allowed through the firewall" />
    </StackPanel>

    <!-- Filter bar card -->
    <Border Grid.Row="2" Classes="card" Padding="12">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="Filter:" VerticalAlignment="Center" FontWeight="SemiBold" />
        <TextBox Name="txtExceptionFilter" Width="320"
                 Watermark="Filter by name, type, path... (-, AND, OR, &quot;phrase&quot;)"
                 TextChanged="TxtExceptionFilter_TextChanged" />
      </StackPanel>
    </Border>

    <!-- DataGrid card -->
    <Border Grid.Row="4" Classes="card" Padding="0">
      <DataGrid Name="dgExceptions"
                x:CompileBindings="True"
                x:DataType="vm:ExceptionListItemViewModel"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                CanUserReorderColumns="False"
                CanUserSortColumns="True"
                SelectionMode="Extended"
                HeadersVisibility="Column"
                BorderThickness="0">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Name" Binding="{Binding Path=Name}" Width="*" MinWidth="140" />
          <DataGridTextColumn Header="Type" Binding="{Binding Path=Type}" Width="100" MinWidth="90" />
          <DataGridTextColumn Header="Path" Binding="{Binding Path=Path}" Width="2*" MinWidth="200" />
          <DataGridTextColumn Header="Date" Binding="{Binding Path=Date}" Width="130" MinWidth="120" />
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <!-- Button bar -->
    <WrapPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Left">
      <Button Name="btnAppAutoDetect" Content="Auto-detect" Margin="0,0,8,4"
              Click="BtnAppAutoDetect_Click" />
      <Button Name="btnAppAdd" Content="Add..." Margin="0,0,8,4"
              Click="BtnAppAdd_Click" />
      <Button Name="btnAppModify" Content="Modify..." Margin="0,0,8,4"
              IsEnabled="False" Click="BtnAppModify_Click" />
      <Button Name="btnAppRemove" Content="Remove" Margin="0,0,8,4"
              IsEnabled="False" Click="BtnAppRemove_Click" />
      <Button Name="btnAppRemoveAll" Content="Remove All" Margin="0,0,8,4"
              Click="BtnAppRemoveAll_Click" />
      <Button Name="btnImport" Content="Import..." Margin="0,0,8,4"
              Click="BtnImport_Click" />
      <Button Name="btnExport" Content="Export..." Margin="0,0,8,4"
              Click="BtnExport_Click" />
    </WrapPanel>

    <!-- Status bar -->
    <TextBlock Grid.Row="8" Name="txtStatus" Classes="hint" Text="Loading..." />

  </Grid>
</UserControl>
