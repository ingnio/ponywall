<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="pylorak.TinyWall.Views.RulesPage"
             x:CompileBindings="True"
             x:DataType="vm:RuleRowViewModel"
             xmlns:vm="using:pylorak.TinyWall.ViewModels">

  <Grid RowDefinitions="Auto,12,Auto,12,*,8,Auto" Margin="16">
    <!-- Header -->
    <DockPanel Grid.Row="0">
      <Button DockPanel.Dock="Right" Name="btnCreateRule" Click="MnuCreate_Click"
              ToolTip.Tip="Create new rule" Padding="8,6" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <TextBlock Text="&#xE710;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" />
          <TextBlock Text="New Rule" VerticalAlignment="Center" />
        </StackPanel>
      </Button>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="Firewall Rules" Classes="pageTitle" />
        <TextBlock Classes="pageTitleInfo" ToolTip.Tip="All active firewall rules from user exceptions, special exceptions, and blocklists" />
      </StackPanel>
    </DockPanel>

    <!-- Filter bar card (matches Connections/History layout) -->
    <Border Grid.Row="2" Classes="card" Padding="12">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBox Name="txtFilter" Width="500"
                 Watermark="Filter by app, protocol, port... (-, AND, OR, &quot;phrase&quot;)"
                 TextChanged="TxtFilter_TextChanged" />
        <Button Content="Refresh" Click="BtnRefresh_Click" />
      </StackPanel>
    </Border>

    <!-- DataGrid -->
    <DataGrid Grid.Row="4" Name="dataGrid"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              CanUserReorderColumns="True"
              CanUserResizeColumns="True"
              CanUserSortColumns="True"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column"
              SelectionMode="Single">
      <DataGrid.ContextMenu>
        <ContextMenu Name="rowContextMenu" Opening="ContextMenu_Opening">
          <MenuItem Header="Create Rule..." Name="mnuCreate" Click="MnuCreate_Click" />
          <MenuItem Header="Modify..." Name="mnuModify" Click="MnuModify_Click" />
          <MenuItem Header="Delete" Name="mnuDelete" Click="MnuDelete_Click" />
        </ContextMenu>
      </DataGrid.ContextMenu>
      <DataGrid.Columns>
        <DataGridTextColumn Header="Action"    Binding="{Binding Path=Action}"          Width="60"  MinWidth="50" />
        <DataGridTextColumn Header="App"       Binding="{Binding Path=App}"             Width="200" MinWidth="100" />
        <DataGridTextColumn Header="Service"   Binding="{Binding Path=Service}"         Width="100" MinWidth="60" />
        <DataGridTextColumn Header="Protocol"  Binding="{Binding Path=Protocol}"        Width="70"  MinWidth="50" />
        <DataGridTextColumn Header="Direction" Binding="{Binding Path=Direction}"       Width="70"  MinWidth="50" />
        <DataGridTextColumn Header="Remote Addresses" Binding="{Binding Path=RemoteAddresses}" Width="150" MinWidth="80" />
        <DataGridTextColumn Header="Remote Ports"     Binding="{Binding Path=RemotePorts}"     Width="100" MinWidth="60" />
        <DataGridTextColumn Header="Local Ports"      Binding="{Binding Path=LocalPorts}"      Width="100" MinWidth="60" />
        <DataGridTextColumn Header="Source"    Binding="{Binding Path=Source}"          Width="180" MinWidth="80" />
        <DataGridTextColumn Header="Rule Name" Binding="{Binding Path=RuleName}"       Width="150" MinWidth="80" />
      </DataGrid.Columns>
    </DataGrid>

    <!-- Status bar -->
    <TextBlock Grid.Row="6" Name="txtStatus" Classes="hint" Text="Loading..." />
  </Grid>
</UserControl>
