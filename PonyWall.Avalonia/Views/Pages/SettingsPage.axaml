<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:pylorak.TinyWall.ViewModels"
             x:Class="pylorak.TinyWall.Views.SettingsPage">

  <ScrollViewer Padding="16,16,16,32">
    <StackPanel Spacing="0">

      <!-- Page title -->
      <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
        <TextBlock Text="Settings" Classes="pageTitle" />
        <TextBlock Classes="pageTitleInfo" ToolTip.Tip="Configure firewall behavior and security options" />
      </StackPanel>

      <!-- ========== General ========== -->
      <TextBlock Text="General" FontSize="14" FontWeight="SemiBold" Margin="0,20,0,8" />

      <Border Background="#1a2535" CornerRadius="4" Padding="16" Margin="0,2">
        <Grid ColumnDefinitions="Auto,12,*,Auto">
          <TextBlock Grid.Column="0" Text="&#xE774;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                     FontSize="20" Foreground="#556677" VerticalAlignment="Center" />
          <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <TextBlock Text="Language" FontWeight="SemiBold" />
            <TextBlock Text="Application display language" FontSize="11" Foreground="#556677" />
          </StackPanel>
          <ComboBox Grid.Column="3" Name="comboLanguages" Width="180" VerticalAlignment="Center" />
        </Grid>
      </Border>

      <Border Background="#1a2535" CornerRadius="4" Padding="16" Margin="0,2">
        <Grid ColumnDefinitions="Auto,12,*,Auto">
          <TextBlock Grid.Column="0" Text="&#xE895;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                     FontSize="20" Foreground="#556677" VerticalAlignment="Center" />
          <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <TextBlock Text="Auto-update check" FontWeight="SemiBold" />
            <TextBlock Text="Automatically check for updates" FontSize="11" Foreground="#556677" />
          </StackPanel>
          <CheckBox Grid.Column="3" Name="chkAutoUpdateCheck" VerticalAlignment="Center" />
        </Grid>
      </Border>

      <Border Background="#1a2535" CornerRadius="4" Padding="16" Margin="0,2">
        <Grid ColumnDefinitions="Auto,12,*,Auto">
          <TextBlock Grid.Column="0" Text="&#xE9CE;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                     FontSize="20" Foreground="#556677" VerticalAlignment="Center" />
          <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <TextBlock Text="Exception details" FontWeight="SemiBold" />
            <TextBlock Text="Ask for details when whitelisting" FontSize="11" Foreground="#556677" />
          </StackPanel>
          <CheckBox Grid.Column="3" Name="chkAskForExceptionDetails" VerticalAlignment="Center" />
        </Grid>
      </Border>

      <Border Background="#1a2535" CornerRadius="4" Padding="16" Margin="0,2">
        <Grid ColumnDefinitions="Auto,12,*,Auto">
          <TextBlock Grid.Column="0" Text="&#xE765;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                     FontSize="20" Foreground="#556677" VerticalAlignment="Center" />
          <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <TextBlock Text="Global hotkeys" FontWeight="SemiBold" />
            <TextBlock Text="Enable global keyboard shortcuts" FontSize="11" Foreground="#556677" />
          </StackPanel>
          <CheckBox Grid.Column="3" Name="chkEnableHotkeys" VerticalAlignment="Center" />
        </Grid>
      </Border>

      <!-- ========== Security ========== -->
      <TextBlock Text="Security" FontSize="14" FontWeight="SemiBold" Margin="0,24,0,8" />

      <Border Background="#1a2535" CornerRadius="4" Padding="16" Margin="0,2">
        <Grid ColumnDefinitions="Auto,12,*,Auto">
          <TextBlock Grid.Column="0" Text="&#xE968;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                     FontSize="20" Foreground="#556677" VerticalAlignment="Center" />
          <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <TextBlock Text="Allow local subnet" FontWeight="SemiBold" />
            <TextBlock Text="Allow traffic on the local network" FontSize="11" Foreground="#556677" />
          </StackPanel>
          <CheckBox Grid.Column="3" Name="chkAllowLocalSubnet" VerticalAlignment="Center" />
        </Grid>
      </Border>

      <Border Background="#1a2535" CornerRadius="4" Padding="16" Margin="0,2">
        <Grid ColumnDefinitions="Auto,12,*,Auto">
          <TextBlock Grid.Column="0" Text="&#xE83D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                     FontSize="20" Foreground="#556677" VerticalAlignment="Center" />
          <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <TextBlock Text="Block when display off" FontWeight="SemiBold" />
            <TextBlock Text="Block traffic when display is off" FontSize="11" Foreground="#556677" />
          </StackPanel>
          <CheckBox Grid.Column="3" Name="chkDisplayOffBlock" VerticalAlignment="Center" />
        </Grid>
      </Border>

      <Border Background="#1a2535" CornerRadius="4" Padding="16" Margin="0,2">
        <Grid ColumnDefinitions="Auto,12,*,Auto">
          <TextBlock Grid.Column="0" Text="&#xE72E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                     FontSize="20" Foreground="#556677" VerticalAlignment="Center" />
          <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <TextBlock Text="Lock hosts file" FontWeight="SemiBold" />
            <TextBlock Text="Prevent modifications to the hosts file" FontSize="11" Foreground="#556677" />
          </StackPanel>
          <CheckBox Grid.Column="3" Name="chkLockHostsFile" VerticalAlignment="Center" />
        </Grid>
      </Border>

      <!-- ========== Notifications ========== -->
      <TextBlock Text="Notifications" FontSize="14" FontWeight="SemiBold" Margin="0,24,0,8" />

      <Border Background="#1a2535" CornerRadius="4" Padding="16" Margin="0,2">
        <Grid ColumnDefinitions="Auto,12,*,Auto">
          <TextBlock Grid.Column="0" Text="&#xEA8F;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                     FontSize="20" Foreground="#556677" VerticalAlignment="Center" />
          <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <TextBlock Text="First-block toasts" FontWeight="SemiBold" />
            <TextBlock Text="Show toast when a new app is blocked" FontSize="11" Foreground="#556677" />
          </StackPanel>
          <CheckBox Grid.Column="3" Name="chkFirstBlockToasts" VerticalAlignment="Center" />
        </Grid>
      </Border>

      <!-- ========== Blocklists ========== -->
      <TextBlock Text="Blocklists" FontSize="14" FontWeight="SemiBold" Margin="0,24,0,8" />

      <Border Background="#1a2535" CornerRadius="4" Padding="16" Margin="0,2">
        <Grid ColumnDefinitions="Auto,12,*,Auto">
          <TextBlock Grid.Column="0" Text="&#xE8D7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                     FontSize="20" Foreground="#556677" VerticalAlignment="Center" />
          <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <TextBlock Text="Enable blocklists" FontWeight="SemiBold" />
            <TextBlock Text="Enable built-in blocklists" FontSize="11" Foreground="#556677" />
          </StackPanel>
          <CheckBox Grid.Column="3" Name="chkEnableBlocklists" VerticalAlignment="Center"
                    Checked="ChkEnableBlocklists_Changed" Unchecked="ChkEnableBlocklists_Changed" />
        </Grid>
      </Border>

      <Border Background="#1a2535" CornerRadius="4" Padding="16" Margin="24,2,0,2">
        <Grid ColumnDefinitions="Auto,12,*,Auto">
          <TextBlock Grid.Column="0" Text="&#xE774;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                     FontSize="18" Foreground="#445566" VerticalAlignment="Center" />
          <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <TextBlock Text="Hosts blocklist" FontWeight="SemiBold" />
            <TextBlock Text="Enable the hosts file blocklist" FontSize="11" Foreground="#556677" />
          </StackPanel>
          <CheckBox Grid.Column="3" Name="chkHostsBlocklist" VerticalAlignment="Center" IsEnabled="False" />
        </Grid>
      </Border>

      <Border Background="#1a2535" CornerRadius="4" Padding="16" Margin="24,2,0,2">
        <Grid ColumnDefinitions="Auto,12,*,Auto">
          <TextBlock Grid.Column="0" Text="&#xE730;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                     FontSize="18" Foreground="#445566" VerticalAlignment="Center" />
          <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <TextBlock Text="Malware ports" FontWeight="SemiBold" />
            <TextBlock Text="Block known malware ports" FontSize="11" Foreground="#556677" />
          </StackPanel>
          <CheckBox Grid.Column="3" Name="chkBlockMalwarePorts" VerticalAlignment="Center" IsEnabled="False" />
        </Grid>
      </Border>

      <!-- ========== Special Exceptions ========== -->
      <TextBlock Text="Special Exceptions" FontSize="14" FontWeight="SemiBold" Margin="0,24,0,8" />

      <!-- Side-by-side: Recommended left, Optional right -->
      <Grid ColumnDefinitions="*,8,*">
        <Border Grid.Column="0" Background="#1a2535" CornerRadius="4" Padding="16">
          <StackPanel Spacing="8">
            <TextBlock Text="Recommended" FontWeight="SemiBold" />
            <ListBox Name="listRecommended" BorderThickness="0" Background="Transparent">
              <ListBox.ItemTemplate>
                <DataTemplate DataType="vm:SpecialExceptionItemViewModel">
                  <CheckBox IsChecked="{Binding IsChecked}" Content="{Binding Name}" Margin="4,2" />
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </Border>

        <Border Grid.Column="2" Background="#1a2535" CornerRadius="4" Padding="16">
          <StackPanel Spacing="8">
            <TextBlock Text="Optional" FontWeight="SemiBold" />
            <ListBox Name="listOptional" BorderThickness="0" Background="Transparent">
              <ListBox.ItemTemplate>
                <DataTemplate DataType="vm:SpecialExceptionItemViewModel">
                  <CheckBox IsChecked="{Binding IsChecked}" Content="{Binding Name}" Margin="4,2" />
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </Border>
      </Grid>

      <!-- ========== Password ========== -->
      <TextBlock Text="Password" FontSize="14" FontWeight="SemiBold" Margin="0,24,0,8" />

      <!-- Change password toggle -->
      <Border Background="#1a2535" CornerRadius="4" Padding="16" Margin="0,2">
        <Grid ColumnDefinitions="Auto,12,*,Auto">
          <TextBlock Grid.Column="0" Text="&#xE72E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                     FontSize="20" Foreground="#556677" VerticalAlignment="Center" />
          <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <TextBlock Text="Change password" FontWeight="SemiBold" />
            <TextBlock Text="Set a password to protect PonyWall settings" FontSize="11" Foreground="#556677" />
          </StackPanel>
          <CheckBox Grid.Column="3" Name="chkChangePassword" VerticalAlignment="Center"
                    Checked="ChkChangePassword_Changed" Unchecked="ChkChangePassword_Changed" />
        </Grid>
      </Border>

      <!-- Password fields (label left, fields right) -->
      <Border Background="#1a2535" CornerRadius="4" Padding="16" Margin="0,2">
        <Grid ColumnDefinitions="Auto,12,*,12,Auto">
          <TextBlock Grid.Column="0" Text="&#xE8D7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                     FontSize="20" Foreground="#556677" VerticalAlignment="Center" />
          <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <TextBlock Text="Password" FontWeight="SemiBold" />
            <TextBlock Text="Enter and confirm your new password" FontSize="11" Foreground="#556677" />
          </StackPanel>
          <StackPanel Grid.Column="4" Spacing="6" VerticalAlignment="Center">
            <TextBox Name="txtPassword" PasswordChar="*" IsEnabled="False"
                     Width="200" Watermark="Password" />
            <TextBox Name="txtPasswordAgain" PasswordChar="*" IsEnabled="False"
                     Width="200" Watermark="Confirm" />
            <Button Name="btnApplyPassword" Content="Apply" IsEnabled="False"
                    Click="BtnApplyPassword_Click" HorizontalAlignment="Right" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Bottom spacer so nothing gets cut off -->
      <Panel Height="80" />

    </StackPanel>
  </ScrollViewer>

</UserControl>
