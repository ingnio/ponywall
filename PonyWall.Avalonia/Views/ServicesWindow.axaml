<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:pylorak.TinyWall.ViewModels"
        x:Class="pylorak.TinyWall.Views.ServicesWindow"
        Title="Windows Services - PonyWall"
        Width="620" Height="420"
        CanResize="True"
        WindowStartupLocation="CenterScreen"
        Topmost="True">

  <Grid Margin="16" RowDefinitions="Auto,12,*,12,Auto">

    <!-- Header -->
    <TextBlock Grid.Row="0" Classes="sectionHeader" Text="Select a Service" />

    <!-- Card around DataGrid -->
    <Border Grid.Row="2" Classes="card" Padding="0">
      <DataGrid Name="dataGrid"
                x:CompileBindings="True"
                x:DataType="vm:ServiceItemViewModel"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                SelectionMode="Single"
                CanUserSortColumns="True"
                CanUserResizeColumns="True"
                HeadersVisibility="Column"
                BorderThickness="0">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="*" />
          <DataGridTextColumn Header="Service Name" Binding="{Binding ServiceName}" Width="*" />
          <DataGridTextColumn Header="Executable Path" Binding="{Binding ExecutablePath}" Width="2*" />
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <!-- Buttons -->
    <StackPanel Grid.Row="4" Classes="buttonRow">
      <Button Name="btnOK" Content="OK" Width="90" IsDefault="True"
              Classes="primary"
              IsEnabled="False"
              Click="BtnOK_Click" />
      <Button Name="btnCancel" Content="Cancel" Width="90" IsCancel="True"
              Click="BtnCancel_Click" />
    </StackPanel>

  </Grid>
</Window>
