<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="pylorak.TinyWall.Views.ProcessesWindow"
        Title="Running Processes - TinyWall"
        Width="620" Height="420"
        CanResize="True"
        WindowStartupLocation="CenterScreen"
        Topmost="True">

  <Grid Margin="16" RowDefinitions="Auto,12,*,12,Auto">

    <!-- Header -->
    <TextBlock Grid.Row="0" Classes="sectionHeader" Text="Select a Process" />

    <!-- Card around DataGrid -->
    <Border Grid.Row="2" Classes="card" Padding="0">
      <DataGrid Name="dataGrid"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                CanUserSortColumns="True"
                CanUserResizeColumns="True"
                HeadersVisibility="Column"
                BorderThickness="0">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
          <DataGridTextColumn Header="Services" Binding="{Binding Services}" Width="*" />
          <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="2*" />
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <!-- Buttons -->
    <StackPanel Grid.Row="4" Classes="buttonRow">
      <Button Name="btnOK" Content="OK" Width="90" IsDefault="True"
              Classes="primary"
              IsEnabled="False"
              Click="BtnOK_Click" />
      <Button Name="btnCancel" Content="Cancel" Width="90" IsCancel="True"
              Click="BtnCancel_Click" />
    </StackPanel>

  </Grid>
</Window>
