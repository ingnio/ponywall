<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:pylorak.TinyWall.ViewModels"
        x:Class="pylorak.TinyWall.Views.SettingsWindow"
        Title="TinyWall Settings"
        Width="720" Height="580"
        MinWidth="620" MinHeight="480"
        CanResize="True"
        WindowStartupLocation="CenterScreen"
        Topmost="True">

  <Grid Margin="16" RowDefinitions="*,12,Auto">

    <!-- Tab Control -->
    <TabControl Grid.Row="0" Name="tabControl">

      <!-- ========== Tab 1: General + Password ========== -->
      <TabItem Header="General">
        <ScrollViewer Padding="4,8">
          <StackPanel Spacing="12">

            <!-- Language card -->
            <Border Classes="card">
              <StackPanel Spacing="8">
                <TextBlock Text="Language" Classes="sectionHeader" />
                <ComboBox Name="comboLanguages" Width="240" />
              </StackPanel>
            </Border>

            <!-- Options card -->
            <Border Classes="card">
              <StackPanel Spacing="4">
                <TextBlock Text="Options" Classes="sectionHeader" />
                <CheckBox Name="chkAutoUpdateCheck" Content="Automatically check for updates" />
                <CheckBox Name="chkAskForExceptionDetails" Content="Ask for exception details when whitelisting" />
                <CheckBox Name="chkEnableHotkeys" Content="Enable global hotkeys" />
              </StackPanel>
            </Border>

            <!-- Password card -->
            <Border Classes="card">
              <StackPanel Spacing="8">
                <TextBlock Text="Password Protection" Classes="sectionHeader" />
                <TextBlock Text="If set, a password will be required to access TinyWall settings."
                           TextWrapping="Wrap" Classes="subtitle" />
                <CheckBox Name="chkChangePassword" Content="Change password"
                          Checked="ChkChangePassword_Changed" Unchecked="ChkChangePassword_Changed" />
                <Grid ColumnDefinitions="Auto,12,*" RowDefinitions="Auto,8,Auto">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Password:" VerticalAlignment="Center" />
                  <TextBox Grid.Row="0" Grid.Column="2" Name="txtPassword"
                           PasswordChar="*" IsEnabled="False" />
                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Confirm:" VerticalAlignment="Center" />
                  <TextBox Grid.Row="2" Grid.Column="2" Name="txtPasswordAgain"
                           PasswordChar="*" IsEnabled="False" />
                </Grid>
              </StackPanel>
            </Border>

          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- ========== Tab 2: Machine Settings ========== -->
      <TabItem Header="Machine Settings">
        <ScrollViewer Padding="4,8">
          <StackPanel Spacing="12">

            <!-- Security card -->
            <Border Classes="card">
              <StackPanel Spacing="4">
                <TextBlock Text="Security" Classes="sectionHeader" />
                <CheckBox Name="chkDisplayOffBlock"
                          Content="Block traffic when display is off" />
                <CheckBox Name="chkLockHostsFile"
                          Content="Lock hosts file" />
              </StackPanel>
            </Border>

            <!-- Blocklists card -->
            <Border Classes="card">
              <StackPanel Spacing="4">
                <TextBlock Text="Blocklists" Classes="sectionHeader" />
                <CheckBox Name="chkEnableBlocklists"
                          Content="Enable blocklists"
                          Checked="ChkEnableBlocklists_Changed" Unchecked="ChkEnableBlocklists_Changed" />
                <StackPanel Margin="24,4,0,0" Spacing="4">
                  <CheckBox Name="chkHostsBlocklist"
                            Content="Enable hosts blocklist" IsEnabled="False" />
                  <CheckBox Name="chkBlockMalwarePorts"
                            Content="Block malware ports" IsEnabled="False" />
                </StackPanel>
              </StackPanel>
            </Border>

          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- ========== Tab 3: Special Exceptions ========== -->
      <TabItem Header="Special Exceptions">
        <Grid Margin="4,8" RowDefinitions="Auto,8,*,16,Auto,8,*">

          <!-- Recommended card -->
          <TextBlock Grid.Row="0" Text="Recommended" Classes="sectionHeader" />
          <Border Grid.Row="2" Classes="card" Padding="0">
            <ListBox Name="listRecommended" BorderThickness="0">
              <ListBox.ItemTemplate>
                <DataTemplate DataType="vm:SpecialExceptionItemViewModel">
                  <CheckBox IsChecked="{Binding IsChecked}" Content="{Binding Name}" Margin="4,2" />
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Border>

          <!-- Optional card -->
          <TextBlock Grid.Row="4" Text="Optional" Classes="sectionHeader" />
          <Border Grid.Row="6" Classes="card" Padding="0">
            <ListBox Name="listOptional" BorderThickness="0">
              <ListBox.ItemTemplate>
                <DataTemplate DataType="vm:SpecialExceptionItemViewModel">
                  <CheckBox IsChecked="{Binding IsChecked}" Content="{Binding Name}" Margin="4,2" />
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Border>

        </Grid>
      </TabItem>

      <!-- ========== Tab 4: Application Exceptions ========== -->
      <TabItem Header="Application Exceptions">
        <Grid Margin="4,8" RowDefinitions="Auto,8,*,12,Auto">

          <!-- Filter card -->
          <Border Grid.Row="0" Classes="card" Padding="10,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Filter:" VerticalAlignment="Center" FontWeight="SemiBold" />
              <TextBox Name="txtExceptionFilter" Width="320"
                       Watermark="Type to filter..."
                       TextChanged="TxtExceptionFilter_TextChanged" />
            </StackPanel>
          </Border>

          <!-- DataGrid card -->
          <Border Grid.Row="2" Classes="card" Padding="0">
            <DataGrid Name="dgExceptions"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserReorderColumns="False"
                      CanUserSortColumns="True"
                      SelectionMode="Extended"
                      BorderThickness="0">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100" />
                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="2*" />
                <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="130" />
              </DataGrid.Columns>
            </DataGrid>
          </Border>

          <!-- Buttons -->
          <WrapPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Left">
            <Button Name="btnAppAutoDetect" Content="Auto-detect" Margin="0,0,8,4"
                    Click="BtnAppAutoDetect_Click" />
            <Button Name="btnAppAdd" Content="Add..." Margin="0,0,8,4"
                    Click="BtnAppAdd_Click" />
            <Button Name="btnAppModify" Content="Modify..." Margin="0,0,8,4"
                    IsEnabled="False" Click="BtnAppModify_Click" />
            <Button Name="btnAppRemove" Content="Remove" Margin="0,0,8,4"
                    IsEnabled="False" Click="BtnAppRemove_Click" />
            <Button Name="btnAppRemoveAll" Content="Remove All" Margin="0,0,8,4"
                    Click="BtnAppRemoveAll_Click" />
            <Button Name="btnImport" Content="Import..." Margin="0,0,8,4"
                    Click="BtnImport_Click" />
            <Button Name="btnExport" Content="Export..." Margin="0,0,8,4"
                    Click="BtnExport_Click" />
          </WrapPanel>

        </Grid>
      </TabItem>

      <!-- ========== Tab 5: About ========== -->
      <TabItem Header="About">
        <ScrollViewer Padding="4,8">
          <StackPanel Spacing="12">

            <!-- App info card -->
            <Border Classes="card">
              <StackPanel Spacing="8">
                <TextBlock Name="lblVersion" Text="TinyWall" Classes="pageTitle" />
                <TextBlock Text="A free, lightweight and non-intrusive firewall."
                           TextWrapping="Wrap" Classes="subtitle" />
              </StackPanel>
            </Border>

            <!-- Links card -->
            <Border Classes="card">
              <StackPanel Spacing="8">
                <TextBlock Text="Links" Classes="sectionHeader" />
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Website:" VerticalAlignment="Center" FontWeight="SemiBold" />
                  <HyperlinkButton Name="btnWebLink" Content="https://tinywall.pados.hu"
                                   NavigateUri="https://tinywall.pados.hu" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="GitHub:" VerticalAlignment="Center" FontWeight="SemiBold" />
                  <HyperlinkButton Name="btnGithubLink" Content="https://github.com/pylorak/tinywall"
                                   NavigateUri="https://github.com/pylorak/tinywall" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="License:" VerticalAlignment="Center" FontWeight="SemiBold" />
                  <HyperlinkButton Name="btnLicenseLink" Content="View License"
                                   Click="BtnLicenseLink_Click" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Attributions:" VerticalAlignment="Center" FontWeight="SemiBold" />
                  <HyperlinkButton Name="btnAttributionsLink" Content="View Attributions"
                                   Click="BtnAttributionsLink_Click" />
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- Actions card -->
            <Border Classes="card">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Name="btnDonate" Content="Donate" Classes="primary" Click="BtnDonate_Click" />
                <Button Name="btnUpdate" Content="Check for Updates" Click="BtnUpdate_Click" />
              </StackPanel>
            </Border>

          </StackPanel>
        </ScrollViewer>
      </TabItem>

    </TabControl>

    <!-- Bottom OK/Cancel -->
    <StackPanel Grid.Row="2" Classes="buttonRow">
      <Button Name="btnOK" Content="OK" Width="90" IsDefault="True"
              Classes="primary"
              Click="BtnOK_Click" />
      <Button Name="btnCancel" Content="Cancel" Width="90" IsCancel="True"
              Click="BtnCancel_Click" />
    </StackPanel>

  </Grid>
</Window>
