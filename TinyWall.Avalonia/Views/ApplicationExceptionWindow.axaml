<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="pylorak.TinyWall.Views.ApplicationExceptionWindow"
        Title="Application Exception - TinyWall"
        Width="520" Height="620"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Topmost="True">

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- Top banner -->
    <Border Grid.Row="0"
            Name="bannerBorder"
            Classes="banner"
            Background="{DynamicResource BannerGradientLight}">
      <TextBlock Name="txtBanner"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 TextAlignment="Center"
                 TextWrapping="Wrap" />
    </Border>

    <!-- Main content -->
    <ScrollViewer Grid.Row="1" Padding="16,12">
      <StackPanel Spacing="12">

        <!-- Subject info card -->
        <Border Classes="card">
          <StackPanel Spacing="8">
            <TextBlock Text="Application Subject" Classes="sectionHeader" />
            <Grid ColumnDefinitions="Auto,12,*" RowDefinitions="Auto,8,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Path:" VerticalAlignment="Center" FontWeight="SemiBold" />
              <TextBox Grid.Row="0" Grid.Column="2" Name="txtAppPath" IsReadOnly="True" />
              <TextBlock Grid.Row="2" Grid.Column="0" Text="Type:" VerticalAlignment="Center" FontWeight="SemiBold" />
              <TextBox Grid.Row="2" Grid.Column="2" Name="txtSrvName" IsReadOnly="True" />
            </Grid>

            <!-- Subject selection buttons -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
              <Button Name="btnBrowse" Content="Browse..." Click="BtnBrowse_Click" />
              <Button Name="btnProcess" Content="Process..." Click="BtnProcess_Click" />
              <Button Name="btnService" Content="Service..." Click="BtnService_Click" />
              <Button Name="btnUwpApp" Content="UWP App..." Click="BtnUwpApp_Click" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Timer -->
        <Border Classes="card">
          <StackPanel Spacing="6">
            <TextBlock Text="Timer" Classes="sectionHeader" />
            <ComboBox Name="cmbTimer"
                      HorizontalAlignment="Stretch"
                      SelectionChanged="CmbTimer_SelectionChanged" />
          </StackPanel>
        </Border>

        <!-- Policy card -->
        <Border Classes="card">
          <StackPanel Spacing="6">
            <TextBlock Text="Restriction Policy" Classes="sectionHeader" />
            <RadioButton Name="radBlock"
                         Content="Block"
                         GroupName="Policy"
                         IsCheckedChanged="RadRestriction_CheckedChanged" />
            <RadioButton Name="radTcpUdpUnrestricted"
                         Content="TCP+UDP Unrestricted"
                         GroupName="Policy"
                         IsCheckedChanged="RadRestriction_CheckedChanged" />
            <RadioButton Name="radTcpUdpOut"
                         Content="Outgoing Only"
                         GroupName="Policy"
                         IsCheckedChanged="RadRestriction_CheckedChanged" />
            <RadioButton Name="radOnlySpecifiedPorts"
                         Content="Only Specified Ports"
                         GroupName="Policy"
                         IsCheckedChanged="RadRestriction_CheckedChanged" />
            <RadioButton Name="radUnrestricted"
                         Content="Unrestricted"
                         GroupName="Policy"
                         IsCheckedChanged="RadRestriction_CheckedChanged" />
          </StackPanel>
        </Border>

        <!-- Port fields card -->
        <Border Name="portFieldsPanel" Classes="card">
          <StackPanel Spacing="6">
            <TextBlock Text="Port Configuration" Classes="sectionHeader" />
            <Grid ColumnDefinitions="Auto,12,*" RowDefinitions="Auto,8,Auto,8,Auto,8,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Outbound TCP:" VerticalAlignment="Center" />
              <TextBox   Grid.Row="0" Grid.Column="2" Name="txtOutboundPortTCP" />

              <TextBlock Grid.Row="2" Grid.Column="0" Text="Outbound UDP:" VerticalAlignment="Center" />
              <TextBox   Grid.Row="2" Grid.Column="2" Name="txtOutboundPortUDP" />

              <TextBlock Grid.Row="4" Grid.Column="0" Text="Listen TCP:" VerticalAlignment="Center"
                         Name="lblListenTCP" />
              <TextBox   Grid.Row="4" Grid.Column="2" Name="txtListenPortTCP" />

              <TextBlock Grid.Row="6" Grid.Column="0" Text="Listen UDP:" VerticalAlignment="Center"
                         Name="lblListenUDP" />
              <TextBox   Grid.Row="6" Grid.Column="2" Name="txtListenPortUDP" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Options card -->
        <Border Classes="card">
          <StackPanel Spacing="4">
            <TextBlock Text="Options" Classes="sectionHeader" />
            <CheckBox Name="chkRestrictToLocalNetwork" Content="Restrict to Local Network" />
            <CheckBox Name="chkInheritToChildren" Content="Inherit to Child Processes" />
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

    <!-- OK / Cancel buttons -->
    <Border Grid.Row="2" Padding="16,8" BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
      <StackPanel Classes="buttonRow">
        <Button Name="btnOK" Content="OK" Width="90" IsDefault="True"
                Classes="primary"
                Click="BtnOK_Click" />
        <Button Name="btnCancel" Content="Cancel" Width="90" IsCancel="True"
                Click="BtnCancel_Click" />
      </StackPanel>
    </Border>

  </Grid>
</Window>
