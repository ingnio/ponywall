<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="pylorak.TinyWall.Views.PasswordWindow"
        Title="Password - PonyWall"
        Width="440" Height="230"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        SystemDecorations="BorderOnly">

  <Grid Margin="16" RowDefinitions="Auto,12,Auto">

    <!-- Card panel -->
    <Border Grid.Row="0" Classes="card">
      <Grid ColumnDefinitions="Auto,16,*" RowDefinitions="Auto,12,Auto">

        <!-- Lock icon -->
        <Image Grid.Row="0" Grid.Column="0" Grid.RowSpan="3"
               Width="48" Height="48"
               VerticalAlignment="Top"
               Source="avares://TinyWall.Avalonia/Assets/firewall.ico" />

        <!-- Label -->
        <TextBlock Grid.Row="0" Grid.Column="2"
                   TextWrapping="Wrap"
                   Text="The requested firewall operation requires additional privileges. Please enter your passphrase to authenticate." />

        <!-- Password box -->
        <TextBox Grid.Row="2" Grid.Column="2"
                 Name="txtPassphrase"
                 PasswordChar="&#x25CF;"
                 Watermark="Password" />
      </Grid>
    </Border>

    <!-- Buttons -->
    <StackPanel Grid.Row="2" Classes="buttonRow">
      <Button Name="btnOK" Content="OK" Width="90" IsDefault="True"
              Classes="primary"
              Click="BtnOK_Click" />
      <Button Name="btnCancel" Content="Cancel" Width="90" IsCancel="True"
              Click="BtnCancel_Click" />
    </StackPanel>

  </Grid>
</Window>
