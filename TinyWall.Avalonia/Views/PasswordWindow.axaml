<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="pylorak.TinyWall.Views.PasswordWindow"
        Title="Password - TinyWall"
        Width="420" Height="210"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        SystemDecorations="BorderOnly">

  <Grid Margin="12" RowDefinitions="Auto,8,Auto,16,Auto" ColumnDefinitions="Auto,12,*">

    <!-- Lock icon -->
    <Image Grid.Row="0" Grid.Column="0" Grid.RowSpan="3"
           Width="48" Height="48"
           VerticalAlignment="Top"
           Source="avares://TinyWall.Avalonia/Assets/firewall.ico" />

    <!-- Label -->
    <TextBlock Grid.Row="0" Grid.Column="2"
               TextWrapping="Wrap"
               Text="The requested firewall operation requires additional privileges. Please enter your passphrase to authenticate." />

    <!-- Password box -->
    <TextBox Grid.Row="2" Grid.Column="2"
             Name="txtPassphrase"
             PasswordChar="●"
             Watermark="Password" />

    <!-- Buttons -->
    <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8">
      <Button Name="btnOK" Content="OK" Width="90" IsDefault="True"
              Click="BtnOK_Click" />
      <Button Name="btnCancel" Content="Cancel" Width="90" IsCancel="True"
              Click="BtnCancel_Click" />
    </StackPanel>

  </Grid>
</Window>
