<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="pylorak.TinyWall.Views.ServicesWindow"
        Title="Windows Services - TinyWall"
        Width="600" Height="400"
        CanResize="True"
        WindowStartupLocation="CenterScreen"
        Topmost="True">

  <Grid Margin="8" RowDefinitions="*,8,Auto">

    <!-- DataGrid -->
    <DataGrid Grid.Row="0"
              Name="dataGrid"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              SelectionMode="Single"
              CanUserSortColumns="True"
              CanUserResizeColumns="True"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="*" />
        <DataGridTextColumn Header="Service Name" Binding="{Binding ServiceName}" Width="*" />
        <DataGridTextColumn Header="Executable Path" Binding="{Binding ExecutablePath}" Width="2*" />
      </DataGrid.Columns>
    </DataGrid>

    <!-- Buttons -->
    <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8">
      <Button Name="btnOK" Content="OK" Width="90" IsDefault="True"
              IsEnabled="False"
              Click="BtnOK_Click" />
      <Button Name="btnCancel" Content="Cancel" Width="90" IsCancel="True"
              Click="BtnCancel_Click" />
    </StackPanel>

  </Grid>
</Window>
