<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="pylorak.TinyWall.Views.TrayMenuWindow"
        Title="PonyWall Menu"
        TransparencyLevelHint="AcrylicBlur,None"
        Background="Transparent"
        SystemDecorations="None"
        ShowInTaskbar="False"
        CanResize="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        MinWidth="240"
        MaxWidth="320">

  <Window.Styles>
    <!-- Menu item button: transparent, full width, rounded hover -->
    <Style Selector="Button.menuItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Margin" Value="4,1" />
    </Style>
    <Style Selector="Button.menuItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}" />
    </Style>
    <Style Selector="Button.menuItem:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListMediumBrush}" />
    </Style>

    <!-- Disabled info row (traffic rate) -->
    <Style Selector="Button.menuInfo">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="IsEnabled" Value="False" />
      <Setter Property="Margin" Value="4,1" />
      <Setter Property="Opacity" Value="0.7" />
    </Style>

    <!-- Separator -->
    <Style Selector="Separator.menuSep">
      <Setter Property="Margin" Value="12,4" />
      <Setter Property="Height" Value="1" />
      <Setter Property="Background" Value="{DynamicResource SystemControlForegroundBaseLowBrush}" />
    </Style>

    <!-- Submenu header (non-clickable, shows expand arrow) -->
    <Style Selector="Button.submenuHeader">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Margin" Value="4,1" />
    </Style>
    <Style Selector="Button.submenuHeader:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}" />
    </Style>

    <!-- (indicator style defined above with Segoe Fluent Icons) -->

    <!-- Submenu child items: indented -->
    <Style Selector="Button.submenuItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Margin" Value="4,0" />
    </Style>
    <Style Selector="Button.submenuItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}" />
    </Style>
    <Style Selector="Button.submenuItem:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListMediumBrush}" />
    </Style>

    <!-- Expand arrow (Segoe Fluent Icons) -->
    <Style Selector="TextBlock.expandArrow">
      <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
    </Style>

    <!-- Menu icon (Segoe Fluent Icons) -->
    <Style Selector="TextBlock.menuIcon">
      <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
      <Setter Property="Width" Value="20" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <!-- Indicator (Segoe Fluent Icons) -->
    <Style Selector="TextBlock.indicator">
      <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
      <Setter Property="Width" Value="20" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextAlignment" Value="Center" />
    </Style>
  </Window.Styles>

  <Border x:Name="MenuBorder"
          CornerRadius="8"
          BorderThickness="1"
          Padding="4,6"
          BoxShadow="0 4 16 0 #30000000"
          ClipToBounds="True">
    <StackPanel>

      <!-- Traffic Rate (info row) -->
      <Button Classes="menuInfo" x:Name="BtnTrafficRate">
        <TextBlock x:Name="TxtTrafficRate" Text="Traffic: --" FontSize="12" />
      </Button>

      <Separator Classes="menuSep" />

      <!-- Change Mode (expandable) -->
      <Button Classes="submenuHeader" x:Name="BtnModeExpand" Click="OnModeExpandClick">
        <DockPanel>
          <TextBlock x:Name="TxtModeArrow" Classes="expandArrow" DockPanel.Dock="Right" Text="&#xE76C;" Margin="8,0,0,0" />
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Classes="menuIcon" Text="&#xEA18;" />
            <TextBlock Text="Change mode" />
          </StackPanel>
        </DockPanel>
      </Button>
      <StackPanel x:Name="PnlModeItems" IsVisible="False" Margin="16,0,0,0">
        <Button Classes="submenuItem" x:Name="BtnModeNormal" Click="OnModeNormalClick">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock x:Name="IndModeNormal" Classes="indicator" Text="●" />
            <TextBlock x:Name="TxtModeNormal" Text="Normal" />
          </StackPanel>
        </Button>
        <Button Classes="submenuItem" x:Name="BtnModeBlockAll" Click="OnModeBlockAllClick">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock x:Name="IndModeBlockAll" Classes="indicator" Text="○" />
            <TextBlock x:Name="TxtModeBlockAll" Text="Block All" />
          </StackPanel>
        </Button>
        <Button Classes="submenuItem" x:Name="BtnModeAllowOutgoing" Click="OnModeAllowOutgoingClick">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock x:Name="IndModeAllowOutgoing" Classes="indicator" Text="○" />
            <TextBlock x:Name="TxtModeAllowOutgoing" Text="Allow Outgoing" />
          </StackPanel>
        </Button>
        <Button Classes="submenuItem" x:Name="BtnModeDisabled" Click="OnModeDisabledClick">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock x:Name="IndModeDisabled" Classes="indicator" Text="○" />
            <TextBlock x:Name="TxtModeDisabled" Text="Disabled" />
          </StackPanel>
        </Button>
        <Button Classes="submenuItem" x:Name="BtnModeAutolearn" Click="OnModeAutolearnClick">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock x:Name="IndModeAutolearn" Classes="indicator" Text="○" />
            <TextBlock x:Name="TxtModeAutolearn" Text="Autolearn" />
          </StackPanel>
        </Button>
      </StackPanel>

      <Separator Classes="menuSep" />

      <!-- Manage -->
      <Button Classes="menuItem" x:Name="BtnManage" Click="OnManageClick">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <TextBlock Classes="menuIcon" Text="&#xE15E;" />
          <TextBlock Text="Settings" />
        </StackPanel>
      </Button>

      <!-- Connections -->
      <Button Classes="menuItem" x:Name="BtnConnections" Click="OnConnectionsClick">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <PathIcon Width="16" Height="16" Data="M22.74 6.33C24.38 8.48 24.21 11.57 22.25 13.54L20.3 15.48C20.01 15.78 19.53 15.78 19.24 15.48L12.52 8.77C12.23 8.47 12.23 8 12.52 7.71L14.47 5.76C16.44 3.79 19.52 3.63 21.68 5.27L24.72 2.22C25.02 1.93 25.49 1.93 25.79 2.22C26.08 2.51 26.08 2.99 25.79 3.28L22.74 6.33ZM19.77 13.89L21.19 12.48C22.75 10.92 22.75 8.38 21.19 6.82C19.62 5.26 17.09 5.26 15.53 6.82L14.11 8.24L19.77 13.89ZM12.78 11.22C13.07 11.51 13.07 11.98 12.78 12.28L10.65 14.4L13.6 17.35L15.72 15.22C16.02 14.93 16.49 14.93 16.78 15.22C17.08 15.52 17.08 15.99 16.78 16.28L14.66 18.41L15.49 19.24C15.78 19.53 15.78 20 15.49 20.3L13.54 22.24C11.57 24.21 8.49 24.37 6.33 22.74L3.29 25.78C2.99 26.07 2.52 26.07 2.22 25.78C1.93 25.49 1.93 25.01 2.22 24.72L5.27 21.68C3.63 19.52 3.8 16.43 5.76 14.46L7.71 12.52C8 12.23 8.48 12.23 8.77 12.52L9.59 13.34L11.72 11.22C12.01 10.92 12.49 10.92 12.78 11.22ZM6.83 21.19C8.39 22.74 10.92 22.74 12.48 21.18L13.9 19.77L8.24 14.11L6.82 15.52C5.26 17.08 5.26 19.61 6.82 21.17L6.82 21.18L6.83 21.19Z" />
          <TextBlock Text="Connections..." />
        </StackPanel>
      </Button>

      <!-- History -->
      <Button Classes="menuItem" x:Name="BtnHistory" Click="OnHistoryClick">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <TextBlock Classes="menuIcon" Text="&#xE81C;" />
          <TextBlock Text="History..." />
        </StackPanel>
      </Button>

      <!-- Stats -->
      <Button Classes="menuItem" x:Name="BtnStats" Click="OnStatsClick">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <TextBlock Classes="menuIcon" Text="&#xE9D9;" />
          <TextBlock Text="Stats..." />
        </StackPanel>
      </Button>

      <!-- Logs -->
      <Button Classes="menuItem" x:Name="BtnLogs" Click="OnLogsClick">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <TextBlock Classes="menuIcon" Text="&#xE7C3;" />
          <TextBlock Text="Open logs folder" />
        </StackPanel>
      </Button>

      <Separator Classes="menuSep" />

      <!-- Whitelist by (expandable) -->
      <Button Classes="submenuHeader" x:Name="BtnWhitelistExpand" Click="OnWhitelistExpandClick">
        <DockPanel>
          <TextBlock x:Name="TxtWhitelistArrow" Classes="expandArrow" DockPanel.Dock="Right" Text="&#xE76C;" Margin="8,0,0,0" />
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Classes="menuIcon" Text="&#xE753;" />
            <TextBlock Text="Whitelist by" />
          </StackPanel>
        </DockPanel>
      </Button>
      <StackPanel x:Name="PnlWhitelistItems" IsVisible="False" Margin="16,0,0,0">
        <Button Classes="submenuItem" Click="OnWhitelistExeClick">
          <TextBlock Text="Executable..." />
        </Button>
        <Button Classes="submenuItem" Click="OnWhitelistProcessClick">
          <TextBlock Text="Process..." />
        </Button>
        <Button Classes="submenuItem" Click="OnWhitelistWindowClick">
          <TextBlock Text="Window..." />
        </Button>
      </StackPanel>

      <Separator Classes="menuSep" />

      <!-- Lock / Unlock -->
      <Button Classes="menuItem" x:Name="BtnLock" Click="OnLockClick">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <TextBlock x:Name="TxtLockIcon" Classes="menuIcon" Text="&#xE785;" />
          <TextBlock x:Name="TxtLock" Text="Lock" />
        </StackPanel>
      </Button>

      <Separator Classes="menuSep" />

      <!-- Theme (expandable) -->
      <Button Classes="submenuHeader" x:Name="BtnThemeExpand" Click="OnThemeExpandClick">
        <DockPanel>
          <TextBlock x:Name="TxtThemeArrow" Classes="expandArrow" DockPanel.Dock="Right" Text="&#xE76C;" Margin="8,0,0,0" />
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Classes="menuIcon" Text="&#xE793;" />
            <TextBlock Text="Theme" />
          </StackPanel>
        </DockPanel>
      </Button>
      <StackPanel x:Name="PnlThemeItems" IsVisible="False" Margin="16,0,0,0">
        <Button Classes="submenuItem" Click="OnThemeSystemClick">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock x:Name="IndThemeSystem" Classes="indicator" Text="●" />
            <TextBlock Text="System" />
          </StackPanel>
        </Button>
        <Button Classes="submenuItem" Click="OnThemeLightClick">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock x:Name="IndThemeLight" Classes="indicator" Text="○" />
            <TextBlock Text="Light" />
          </StackPanel>
        </Button>
        <Button Classes="submenuItem" Click="OnThemeDarkClick">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock x:Name="IndThemeDark" Classes="indicator" Text="○" />
            <TextBlock Text="Dark" />
          </StackPanel>
        </Button>
      </StackPanel>

      <Separator Classes="menuSep" />

      <!-- Quit -->
      <Button Classes="menuItem" x:Name="BtnQuit" Click="OnQuitClick">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <TextBlock Classes="menuIcon" Text="&#xE7E8;" />
          <TextBlock Text="Quit" />
        </StackPanel>
      </Button>

    </StackPanel>
  </Border>
</Window>
